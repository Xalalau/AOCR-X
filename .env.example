## General
# true enables detailed logs/full alerts; false sends minimal alerts and less console output.
DEBUG_AOCR=false
# Discord bot token used for login.
DISCORD_TOKEN="Token for a discord bot"
# true applies checks to moderators too; false exempts members with Manage Guild.
APPLY_TO_MODERATORS=true
# true sends a DM to detected users; false only acts/logs in the server.
SEND_DETECTION_DM=false

## Recurrent spam policy, shared by OCR and classic text spam
# true enables global recurrent-spam bans; false keeps normal policy only.
SPAM_RECURRENT_BAN_USER=false
# Minutes where repeated detections count as the same spam wave.
SPAM_RECURRENT_GRACE_MINUTES=2
# Counted waves allowed before ban; with 2, the third counted wave bans.
SPAM_RECURRENT_ALLOWED_WAVES=2
# Days without detections before the persisted counter resets.
SPAM_RECURRENT_RESET_DAYS=7

## OCR / image moderation
# Main OCR engine: tesseract or paddle.
OCR_ENGINE=paddle
# HTTP endpoint for the PaddleOCR sidecar service.
OCR_PADDLE_URL=http://127.0.0.1:8000/ocr
# Seconds before a PaddleOCR request times out.
OCR_PADDLE_TIMEOUT_SECONDS=120
# true falls back to Tesseract when Paddle fails; false lets the OCR fail.
OCR_PADDLE_FALLBACK_TO_TESSERACT=true
# true downloads the image in the bot and sends base64; false sends the URL.
OCR_PADDLE_SEND_IMAGE_BASE64=true
# true falls back when Paddle returns empty text.
OCR_PADDLE_FALLBACK_ON_EMPTY_TEXT=true
# Tesseract worker count; used only by tesseract engine/fallback.
OCR_TESSERACT_WORKERS=10
# true applies the Tesseract non-SIMD patch during postinstall; false skips it.
OCR_FORCE_TESSERACT_NOSIMD=true
# true OCR-checks custom emojis used in message text.
OCR_CHECK_EMOJIS=false
# true OCR-checks image emojis from new reactions.
OCR_CHECK_REACTIONS=true
# true OCR-checks stickers as images.
OCR_CHECK_STICKERS=true
# Seconds to wait before OCR starts so text spam can delete first.
OCR_START_DELAY_SECONDS=5

## Classic repeated-text spam detector, not OCR
# Maximum recent text messages kept in detector memory.
TEXT_SPAM_MEMORY_SIZE=250
# Seconds of message history considered for duplicate matching.
TEXT_SPAM_MEMORY_TIMEOUT=60
# Seconds to collect matching spam messages before processing the wave.
TEXT_SPAM_DELAY_SECONDS=3
# true times out users for classic text spam when not banning.
TEXT_SPAM_SILENCE_USER=true
# Timeout duration in seconds; 0 disables timeout.
TEXT_SPAM_SILENCE_TIMEOUT=60
# true directly bans for classic text spam; false uses timeout/delete policy.
TEXT_SPAM_BAN_USER=false
# Minimum equal messages required for spam; code minimum is 2, default is 3.
TEXT_SPAM_DUPLICATE_THRESHOLD=3
# true lets equal messages from different users count toward the same spam wave.
TEXT_SPAM_CROSS_USER_MATCHING=false
# Alert channel(s): one channelId, or comma-separated guildId:channelId entries.
TEXT_SPAM_ALERT_CHANNEL_ID=
